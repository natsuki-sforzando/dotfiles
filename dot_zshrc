setopt BANG_HIST              # Treat the '!' character specially during expansion
setopt EXTENDED_HISTORY       # Write the history file in the ':start:elapsed;command' format
setopt SHARE_HISTORY          # Share history between all sessions
setopt HIST_EXPIRE_DUPS_FIRST # Expire a duplicate event first when trimming history
setopt HIST_IGNORE_DUPS       # Do not record an event that was just recorded again
setopt HIST_IGNORE_ALL_DUPS   # Delete an old recorded event if a new event is a duplicate
setopt HIST_FIND_NO_DUPS      # Do not display a previously found event
setopt HIST_IGNORE_SPACE      # Do not record an event starting with a space
setopt HIST_SAVE_NO_DUPS      # Do not write a duplicate event to the history file
setopt HIST_VERIFY            # Do not execute immediately upon history expansion

source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# bat: https://github.com/sharkdp/bat
if (( $+commands[bat] )); then
  alias cat="bat"
fi

# chezmoi: https://www.chezmoi.io
if (( $+commands[chezmoi] )); then
  eval "$(chezmoi completion zsh)"
fi

# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

# Enable Zsh completion (after brew shellenv so Homebrew completions are in fpath)
autoload -Uz compinit && compinit

# direnv: https://github.com/direnv/direnv
if (( $+commands[direnv] )); then
  eval "$(direnv hook zsh)"
fi

# eza: Modern, maintained replacement for ls
if (( $+commands[eza] )); then
  alias ls="eza -hF --icons"
  alias l="eza -haF --icons"
  alias la="eza -haF --icons"
  alias ll="eza -halF --icons --git"

  # Auto-list files on directory change
  # Use add-zsh-hook instead of defining chpwd() directly
  # to avoid overriding chpwd_functions array used by shell integrations
  _auto_ls_eza() {
    eza -halF --icons --git
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook chpwd _auto_ls_eza
else
  _auto_ls_default() {
    ls -GlA
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook chpwd _auto_ls_default
fi

# fzf
source <(fzf --zsh)

# Git
alias g="git"
compdef g=git

# ghq
if (( $+commands[ghq] )); then
  alias repos="ghq list | fzf --preview 'bat --color=always --style=header,grid --line-range :80 $(ghq root)/{}/README.*'"
  alias repo='cd $(ghq root)/$(repos)'
fi

# mise
eval "$(mise activate zsh)"

# navi
if (( $+commands[navi] )); then
  eval "$(navi widget zsh)"
fi

# starship
eval "$(starship init zsh)"

# Visual Studio Code
if (( $+commands[code] )); then
  export EDITOR="code"
fi
[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"

# Claude Code
export PATH="$HOME/.local/bin:$PATH"

# wtp (Worktree Plus)
eval "$(wtp shell-init zsh)"
